# =============================================================================
# Video CT · Docker 环境变量
# 使用方式：docker compose --env-file .env.docker up -d
# =============================================================================

# ---------- 基础 ----------
NODE_ENV=development
LOG_LEVEL=info
APP_NAME=video-ct
APP_VERSION=0.1.0

# ---------- 数据库 · PostgreSQL ----------
# 生产环境请替换 <db-password> 为强密码（openssl rand -hex 32）
POSTGRES_USER=video_ct
POSTGRES_PASSWORD=video_ct_dev_pwd
POSTGRES_DB=video_ct
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://video_ct:video_ct_dev_pwd@postgres:5432/video_ct

# ---------- Redis ----------
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ---------- MinIO (对象存储 mock) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=video-ct-dev
OSS_ENDPOINT=local
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin123
OSS_BUCKET=video-ct-dev

# ---------- JWT ----------
JWT_SECRET=dev-docker-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---------- AI · DeepSeek ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# ---------- AI · 硅基流动 ----------
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL_EMBEDDING=BAAI/bge-large-zh-v1.5
SILICONFLOW_MODEL_RERANK=BAAI/bge-reranker-v2-m3
SILICONFLOW_MODEL_VISION=Qwen/Qwen2-VL-72B-Instruct
SILICONFLOW_MODEL_LLM_FALLBACK=Qwen/Qwen2.5-72B-Instruct

# ---------- 微信生态 ----------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=

# ---------- 平台 OAuth ----------
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=

# ---------- 短信 ----------
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_ACCESS_SECRET=

# ---------- 存储 ----------
STORAGE_LOCAL_PATH=./storage/uploads

# ---------- 业务参数 ----------
FREE_MONTHLY_SCANS=3
PRO_PRICE_CNY=99
MAX_PRICE_CNY=499
SINGLE_SCAN_PRICE_CNY=19
REFERRER_REWARD_CNY=18
REFERRER_DEDUCT_THRESHOLD=99

# ---------- 风控 ----------
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=200

# ---------- 前端 H5 ----------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=视频CT
VITE_ENABLE_MOCK=false
