{
  "name": "@video-ct/h5",
  "version": "0.1.0",
  "private": true,
  "description": "视频 CT · C 端 H5 应用",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const r=require('child_process').execSync('grep -rn \\\"import eruda from\\\" src/ 2>/dev/null || true').toString();if(r.trim()){console.error('\\u274c 发现静态 import eruda，禁止构建！请改用 import.meta.env.DEV 动态导入');process.exit(1)}else{console.log('\\u2705 Eruda 安全检查通过')}\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@video-ct/shared": "workspace:*",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "pinia": "^3.0.4",
    "vant": "^4.9.10",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.9.1",
    "eruda": "^3.4.3",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "sass-embedded": "^1.83.0",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
