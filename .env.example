# =============================================================================
# Video CT · 环境变量示例文件
# 使用方法：cp .env.example .env.local，然后填入真实值
# .env.local 永远不会被 commit（已在 .gitignore 中排除）
# =============================================================================

# ---------- 基础 ----------
NODE_ENV=development
LOG_LEVEL=info
APP_NAME=video-ct
APP_VERSION=0.1.0

# ---------- 后端服务 ----------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---------- 数据库 ----------
# 开发环境默认走 SQLite（零配置）
DATABASE_URL=sqlite:///./storage/video_ct.db
# 生产 / Docker Compose 切到 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://video_ct:<db-password>@localhost:5432/video_ct

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- AI 模型供应商 ----------
# DeepSeek 官方（PRO 主力 + MAX 推理）
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# 硅基流动 SiliconFlow（多模型聚合：Embedding / 视觉 / 重排序 / 备选 LLM）
SILICONFLOW_API_KEY=<your-siliconflow-api-key>
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL_EMBEDDING=BAAI/bge-large-zh-v1.5
SILICONFLOW_MODEL_RERANK=BAAI/bge-reranker-v2-m3
SILICONFLOW_MODEL_VISION=Qwen/Qwen2-VL-72B-Instruct
SILICONFLOW_MODEL_LLM_FALLBACK=Qwen/Qwen2.5-72B-Instruct

# ---------- 微信生态 ----------
WECHAT_APP_ID=<wechat-mini-program-appid>
WECHAT_APP_SECRET=<wechat-app-secret>
WECHAT_PAY_MCH_ID=<wechat-pay-merchant-id>
WECHAT_PAY_API_KEY=<wechat-pay-api-key>
WECHAT_PAY_CERT_PATH=./secrets/wechat_pay_cert.pem

# ---------- 短视频平台 OAuth（用户授权数据采集）----------
DOUYIN_CLIENT_KEY=<douyin-open-platform-client-key>
DOUYIN_CLIENT_SECRET=<douyin-open-platform-client-secret>
KUAISHOU_CLIENT_KEY=<kuaishou-open-platform-client-key>
KUAISHOU_CLIENT_SECRET=<kuaishou-open-platform-client-secret>

# ---------- 短信 ----------
ALIYUN_SMS_ACCESS_KEY=<aliyun-access-key>
ALIYUN_SMS_ACCESS_SECRET=<aliyun-access-secret>
ALIYUN_SMS_SIGN_NAME=视频CT
ALIYUN_SMS_TEMPLATE_OTP=<aliyun-sms-template-code>

# ---------- 对象存储 ----------
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY=<oss-access-key>
OSS_SECRET_KEY=<oss-secret-key>
OSS_BUCKET=video-ct
OSS_REGION=cn-hangzhou

# ---------- 前端（H5）----------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=视频CT
VITE_ENABLE_MOCK=false

# ---------- 业务参数 ----------
FREE_MONTHLY_SCANS=3
PRO_PRICE_CNY=99
MAX_PRICE_CNY=499
SINGLE_SCAN_PRICE_CNY=19
REFERRER_REWARD_CNY=18
REFERRER_DEDUCT_THRESHOLD=99

# ---------- 风控 ----------
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=200
