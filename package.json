{
  "name": "video-ct",
  "version": "0.1.0",
  "private": true,
  "description": "视频 CT · 短视频博主诊断 + 对标 + 陪跑 SaaS",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "husky install",
    "dev:h5": "pnpm --filter @video-ct/h5 dev",
    "dev:admin": "pnpm --filter @video-ct/admin dev",
    "dev:consultant": "pnpm --filter @video-ct/consultant dev",
    "build": "pnpm -r build",
    "build:h5": "pnpm --filter @video-ct/h5 build",
    "build:admin": "pnpm --filter @video-ct/admin build",
    "build:consultant": "pnpm --filter @video-ct/consultant build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "lint:commits": "commitlint --from HEAD~10 --to HEAD --verbose"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.py": []
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "danger": "^12.3.3",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3"
  }
}