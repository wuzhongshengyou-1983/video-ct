# =============================================================================
# Video CT · C 端 H5 前端 Dockerfile
# 多阶段构建：Node 构建 → Nginx 服务
# =============================================================================

# --------------------------- Stage 1: Build ---------------------------
FROM node:20-alpine AS builder

WORKDIR /build

# 安装 pnpm
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate

# 复制 workspace 配置
COPY pnpm-workspace.yaml .
COPY package.json .
COPY pnpm-lock.yaml* ./

# 复制 apps/h5 源码
COPY apps/h5/package.json apps/h5/
COPY apps/h5/tsconfig.json apps/h5/
COPY apps/h5/vite.config.ts apps/h5/
COPY apps/h5/index.html apps/h5/
COPY apps/h5/env.d.ts apps/h5/
COPY apps/h5/src/ apps/h5/src/
COPY apps/h5/public/ apps/h5/public/ 2>/dev/null || true

# 复制共享 packages（如有）
COPY packages/ packages/ 2>/dev/null || true

# 安装依赖 + 构建
RUN pnpm install --frozen-lockfile --filter @video-ct/h5 \
    && pnpm --filter @video-ct/h5 build

# --------------------------- Stage 2: Nginx ---------------------------
FROM nginx:1.27-alpine

# 安装 envsubst 用于环境变量替换
RUN apk add --no-cache curl

# 复制构建产物
COPY --from=builder /build/apps/h5/dist /usr/share/nginx/html

# 复制 Nginx 配置
COPY infra/docker/nginx/default.conf /etc/nginx/conf.d/default.conf

# 启动前替换环境变量
COPY infra/docker/nginx/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=5s \
    CMD curl -f http://localhost:80/ || exit 1

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
