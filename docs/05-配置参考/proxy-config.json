{
  "proxy_port": 7070,
  "request_timeout": 120,
  "notify_macos": true,
  "auto_mode": {
    "primary": "deepseek",
    "fallback": "deepseek",
    "economy": "siliconflow",
    "quota_limit_tokens": 45000,
    "switch_threshold": 0.88,
    "window_hours": 5,
    "fallback_fail_limit": 3,
    "economy_fail_limit": 5,
    "health_check_interval": 60
  },
  "providers": {
    "deepseek": {
      "name": "DeepSeek",
      "api_key": "$DEEPSEEK_KEY"
    },
    "siliconflow": {
      "name": "硅基流动 SiliconFlow",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key": "$SILICONFLOW_KEY",
      "auth_header": "bearer",
      "format": "openai",
      "model": "deepseek-ai/DeepSeek-V4-Flash"
    },
    "sf-v32": {
      "name": "DeepSeek-V3.2 (硅基流动)",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key": "$SILICONFLOW_KEY",
      "auth_header": "bearer",
      "format": "openai",
      "model": "deepseek-ai/DeepSeek-V3.2"
    },
    "sf-coder": {
      "name": "Qwen3-Coder (硅基流动)",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key": "$SILICONFLOW_KEY",
      "auth_header": "bearer",
      "format": "openai",
      "model": "Qwen/Qwen3-Coder-30B-A3B-Instruct"
    },
    "sf-vision": {
      "name": "Qwen3-VL 视觉 (硅基流动)",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key": "$SILICONFLOW_KEY",
      "auth_header": "bearer",
      "format": "openai",
      "model": "Qwen/Qwen3-VL-32B-Instruct"
    }
  }
}
